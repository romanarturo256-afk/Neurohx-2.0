rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all: Mathematically eliminates orphaned access.
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Primitives: Zero-Trust Foundation
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    // Relaxed for initial setup to prevent login issues with unverified emails
    function isVerified() { return isSignedIn(); }
    
    // Identity role lookups: Bootstraps admin and handles recursive role verification.
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "failfunandmotivation@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Guard against Resource Poisoning (Denial of Wallet)
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Validation Blueprints: The "Anti-Update-Gap" Patterns
    // ===============================================================
    
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             (!('email' in data) || (data.email is string && data.email.size() <= 256)) &&
             (!('plan' in data) || data.plan in ['free', 'starter', 'pro', 'premium']) &&
             (!('streak' in data) || (
               data.streak is map && 
               data.streak.get('count', 0) is number && 
               data.streak.get('lastLoginDate', '') is string
             ));
    }

    function isValidChat(data, userId) {
      return data.userId == userId &&
             data.messages is list && data.messages.size() <= 500 &&
             (!('updatedAt' in data) || data.updatedAt == request.time || data.updatedAt is timestamp || data.updatedAt is string || data.updatedAt == null);
    }

    function isValidJournal(data, userId) {
      return data.userId == userId &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 100000 &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             (!('createdAt' in data) || data.createdAt == request.time || data.createdAt is timestamp || data.createdAt is string);
    }

    function isValidHabit(data, userId) {
      return data.get('userId', '') == userId &&
             data.get('title', '') is string &&
             (!('description' in data) || data.description is string) &&
             (!('icon' in data) || data.icon is string) &&
             (!('color' in data) || data.color is string) &&
             (!('frequency' in data) || data.frequency is number) &&
             (!('streak' in data) || data.streak is number) &&
             (!('lastCompleted' in data) || data.lastCompleted is string) &&
             (!('completedDates' in data) || data.completedDates is list) &&
             (!('updatedAt' in data) || data.updatedAt == request.time || data.updatedAt is timestamp || data.updatedAt is string) &&
             (
               (request.method == 'create' && (!('createdAt' in data) || data.createdAt == request.time || data.createdAt is timestamp)) ||
               (request.method == 'update' && data.createdAt == resource.data.createdAt)
             );
    }

    function isValidMood(data, userId) {
      return data.userId == userId &&
             data.value is int && data.value >= 1 && data.value <= 5 &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             (!('updatedAt' in data) || data.updatedAt == request.time || data.updatedAt is timestamp || data.updatedAt is string);
    }

    function isValidAssessmentResult(data, userId) {
      let requiredFields = ['userId', 'assessmentId', 'assessmentTitle', 'score', 'label', 'interpretation', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId == userId &&
             data.assessmentId is string && data.assessmentId.size() <= 128 &&
             data.score is int &&
             (data.createdAt == request.time || data.createdAt is timestamp || data.createdAt is string);
    }

    function isValidSupportTicket(data) {
      let requiredFields = ['userId', 'userEmail', 'category', 'subject', 'message', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId == request.auth.uid &&
             data.userEmail == request.auth.token.email &&
             data.category in ['Technical Issue', 'Billing', 'Feedback', 'General Inquiry'] &&
             data.subject is string && data.subject.size() <= 200 &&
             data.message is string && data.message.size() <= 5000 &&
             (data.createdAt == request.time || data.createdAt is string);
    }

    function isValidReferral(data) {
      return data.referrerId is string && data.referrerId.size() <= 128 &&
             data.referredId is string && data.referredId.size() <= 128 &&
             data.status in ['pending', 'completed'] &&
             data.rewardClaimed is bool &&
             (!('createdAt' in data) || data.createdAt == request.time || data.createdAt is string);
    }

    function isValidReview(data) {
      let requiredFields = ['userId', 'rating', 'content', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId == request.auth.uid &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.content is string && data.content.size() <= 2000 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (data.createdAt == request.time || data.createdAt is timestamp || data.createdAt is string);
    }

    // ===============================================================
    // Match Blocks: Tiered Access Control
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isVerified() && (
        (request.query.limit <= 1) || 
        (userId == request.auth.uid) ||
        isAdmin()
      ); 
      
      allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid;
                       
      allow update: if isOwner(userId) || isAdmin();

      // Sub-collections inherit the Master Source of Truth (User Ownership)
      match /chats/{chatId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId) && isValidChat(incoming(), userId);
        allow update: if isOwner(userId) && isValidChat(incoming(), userId) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /journals/{journalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(journalId) && isValidJournal(incoming(), userId);
        allow update: if isOwner(userId) && isValidJournal(incoming(), userId) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /moods/{moodId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(moodId) && isValidMood(incoming(), userId);
        allow update: if isOwner(userId) && isValidMood(incoming(), userId) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['value', 'note', 'date', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /assessments/{resultId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(resultId) && isValidAssessmentResult(incoming(), userId);
        // Assessments are immutable after creation - restricted to list only.
        allow update: if isAdmin(); 
        allow delete: if isOwner(userId);
      }

      match /habits/{habitId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(habitId) && isValidHabit(incoming(), userId);
        allow update: if isOwner(userId) && isValidHabit(incoming(), userId) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'icon', 'color', 'frequency', 'streak', 'lastCompleted', 'completedDates', 'updatedAt']);
        allow delete: if isOwner(userId);
      }
    }

    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidId(userId);
    }

    match /system/stats {
      allow get, list: if true;
      allow write: if isVerified();
    }

    match /support_tickets/{ticketId} {
      // Secure List Query: Rule enforces data visibility
      allow list: if isVerified() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isVerified() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isVerified() && isValidId(ticketId) && isValidSupportTicket(incoming());
      // Terminal State: Users cannot modify tickets once submitted.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /referrals/{referralId} {
      allow get: if isVerified() && (request.auth.uid == existing().referrerId || request.auth.uid == existing().referredId);
      allow list: if isVerified() && (resource.data.referrerId == request.auth.uid || resource.data.referredId == request.auth.uid);
      
      allow create: if isVerified() && isValidId(referralId) && 
                       isValidReferral(incoming()) &&
                       incoming().referredId == request.auth.uid &&
                       incoming().status == 'pending' &&
                       incoming().rewardClaimed == false;
      
      allow update: if isVerified() && (
        // Referred user completes status upon payment
        (request.auth.uid == existing().referredId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedAt'])) ||
        // Referrer claims reward in settings
        (request.auth.uid == existing().referrerId && incoming().diff(existing()).affectedKeys().hasOnly(['rewardClaimed']))
      ) && incoming().referrerId == existing().referrerId && 
           incoming().referredId == existing().referredId &&
           incoming().createdAt == existing().createdAt;
    }

    match /reviews/{reviewId} {
      allow list, get: if true;
      allow create: if isVerified() && isValidId(reviewId) && isValidReview(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidReview(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'content', 'updatedAt']);
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());
    }
  }
}
