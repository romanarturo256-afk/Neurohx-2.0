{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and settings information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "starter", "pro", "premium"] },
        "basePlan": { "type": "string", "enum": ["free", "starter", "pro", "premium"] },
        "proExpiry": { "type": "string", "format": "date-time" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "theme": { "type": "object" },
        "settings": { "type": "object" },
        "streak": {
          "type": "object",
          "properties": {
            "count": { "type": "integer" },
            "lastLoginDate": { "type": "string", "format": "date" },
            "lastFreezeUsed": { "type": "string", "format": "date" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "plan", "createdAt"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A conversation between a user and the AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        },
        "updatedAt": { "type": "string" }
      }
    },
    "Journal": {
      "title": "Journal Entry",
      "description": "User reflections and journal logs.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Mood": {
      "title": "Mood Log",
      "description": "Daily mood rating.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "value": { "type": "integer" },
        "date": { "type": "string" }
      }
    },
    "AssessmentResult": {
      "title": "Assessment Result",
      "description": "Output of a clinical assessment.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "assessmentId": { "type": "string" },
        "assessmentTitle": { "type": "string" },
        "score": { "type": "integer" },
        "label": { "type": "string" },
        "interpretation": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "User support inquiry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "category": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Referral": {
      "title": "Referral Record",
      "description": "Connection between referrer and referred user.",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "referredId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "rewardClaimed": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    },
    "Habit": {
      "title": "Habit",
      "description": "Advanced habit tracking with streaks and frequency.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "frequency": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastCompleted": { "type": "string" },
        "completedDates": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "frequency"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Top-level user profile" },
    "/users/{userId}/chats/{chatId}": { "schema": "Chat", "description": "Chat history subcollection" },
    "/users/{userId}/journals/{journalId}": { "schema": "Journal", "description": "Journal subcollection" },
    "/users/{userId}/moods/{moodId}": { "schema": "Mood", "description": "Mood subcollection" },
    "/users/{userId}/assessments/{resultId}": { "schema": "AssessmentResult", "description": "Assessment results subcollection" },
    "/users/{userId}/habits/{habitId}": { "schema": "Habit", "description": "Habit tracking subcollection" },
    "/presence/{userId}": { "schema": "object", "description": "Real-time user presence tracking" },
    "/system/stats": { "schema": "object", "description": "Global application statistics" },
    "/support_tickets/{ticketId}": { "schema": "SupportTicket", "description": "Global support tickets" },
    "/referrals/{referralId}": { "schema": "Referral", "description": "Global referral tracking" }
  }
}
